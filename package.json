{
  "name": "twitch-orders-collector",
  "version": "0.1.0",
  "description": "Localhost-only Electron desktop utility for collecting Twitch chat item requests.",
  "main": "electron/main.js",
  "author": "",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=26.2.0"
  },
  "volta": {
    "node": "26.2.0"
  },
  "scripts": {
    "dev": "node scripts/dev.js",
    "start": "electron .",
    "build": "vite build",
    "build:renderer": "vite build",
    "dist": "npm run build:renderer && electron-builder --win nsis",
    "dist:win": "npm run build:renderer && electron-builder --win nsis --x64",
    "rebuild:native": "node -e \"console.log('No native rebuild required; sqlite is provided via sql.js.')\""
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "sql.js": "^1.13.0",
    "vue": "^3.5.13",
    "vuetify": "^4.0.8",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@vitejs/plugin-vue": "^5.2.1",
    "electron-builder": "^26.0.12",
    "electron": "^42.3.0",
    "vite": "^6.3.5",
    "vite-plugin-vuetify": "^2.1.3"
  },
  "build": {
    "appId": "com.franc.twitchorderscollector",
    "productName": "Twitch Orders Collector",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "core/**/*",
      "src/**/*",
      "dist/renderer/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    }
  }
}
